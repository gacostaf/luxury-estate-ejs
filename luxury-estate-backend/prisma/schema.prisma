/*
 * Possible values:
 * 1  In-Person Tour
 * 2  Virtual Tour
 * 3  Private Showing
 * 4  Open House Visit
 * 5  Broker Tour
 * 6  Video Walkthrough
 * 7  New Construction Tour
 * 8  Investment Property Tour
 */
model TourType {
  id           Int          @id @default(autoincrement()) @map("ID")
  tenantId     Int          @map("TENANT_ID")
  code         String       @map("CODE")
  name         String       @map("NAME")
  description  String?      @map("DESCRIPTION") @db.Text
  isActive     Boolean      @default(true) @map("IS_ACTIVE")
  sortOrder    Int          @default(0) @map("SORT_ORDER")
  createdAt    DateTime     @default(now()) @map("CREATED_AT")
  updatedAt    DateTime     @updatedAt @map("UPDATED_AT")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  tourRequests TourRequest[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("TOUR_TYPES")
}

model TourRequest {
  id                  Int        @id @default(autoincrement()) @map("ID")
  tenantId            Int        @map("TENANT_ID")
  propertyId          Int        @map("PROPERTY_ID")
  clientPersonId      Int?       @map("CLIENT_PERSON_ID")
  clientFirstName     String     @map("CLIENT_FIRST_NAME") @db.VarChar(100)
  clientLastName      String     @map("CLIENT_LAST_NAME") @db.VarChar(100)
  clientEmail         String     @map("CLIENT_EMAIL") @db.VarChar(255)
  clientPhone         String?    @map("CLIENT_PHONE") @db.VarChar(50)
  primaryAssociateId  Int        @map("PRIMARY_ASSOCIATE_ID")
  secondaryAssociateId Int?      @map("SECONDARY_ASSOCIATE_ID")
  tourTypeId          Int        @map("TOUR_TYPE_ID")
  scheduledDate       DateTime   @map("SCHEDULED_DATE")
  clientMessage       String?    @map("CLIENT_MESSAGE") @db.Text
  associateNotes      String?    @map("ASSOCIATE_NOTES") @db.Text
  tourStatusId        Int        @map("TOUR_STATUS_ID")
  contactMethodId Int? @map("CONTACT_METHOD_ID")
  contactMethod   ContactMethod? @relation(fields: [contactMethodId], references: [id])
  leadSourceId Int? @map("LEAD_SOURCE_ID")
  leadSource   LeadSource? @relation(fields: [leadSourceId], references: [id])
  createdAt           DateTime   @default(now()) @map("CREATED_AT")
  updatedAt           DateTime   @updatedAt @map("UPDATED_AT")

  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  property           Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  clientPerson       Person?    @relation("ClientTourRelation", fields: [clientPersonId], references: [id], onDelete: SetNull)
  primaryAssociate   Associate  @relation("PrimaryAssociateTourRelation", fields: [primaryAssociateId], references: [id])
  secondaryAssociate Associate? @relation("SecondaryAssociateTourRelation", fields: [secondaryAssociateId], references: [id])
  tourType           TourType   @relation(fields: [tourTypeId], references: [id])
  tourStatus         TourStatus @relation(fields: [tourStatusId], references: [id])


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([propertyId])
  @@index([primaryAssociateId])
  @@index([secondaryAssociateId])
  @@index([tourTypeId])
  @@index([tourStatusId])
  @@index([tenantId], name: "idx_tr_tenant")
  @@map("TOUR_REQUESTS")
}

