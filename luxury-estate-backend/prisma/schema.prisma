// 2. The ContactRequest Model

model ContactRequest {
  id          Int     @id @default(autoincrement()) @map("ID")
  tenantId    Int     @map("TENANT_ID")
  firstName   String  @map("FIRST_NAME") @db.VarChar(100)
  lastName    String  @map("LAST_NAME") @db.VarChar(100)
  email       String  @map("EMAIL") @db.VarChar(255)
  phone       String? @map("PHONE_NUMBER") @db.VarChar(50)
  companyName String? @map("COMPANY_NAME") @db.VarChar(150)
  jobTitle    String? @map("JOB_TITLE") @db.VarChar(100)

  requestTypeId Int     @map("REQUEST_TYPE_ID")
  subject       String? @map("SUBJECT") @db.VarChar(255)
  message       String  @map("MESSAGE") @db.Text
  contactMethodId Int? @map("CONTACT_METHOD_ID")
  contactMethod   ContactMethod? @relation(fields: [contactMethodId], references: [id])

  // Marketing Attribution (UTMs)
  utmSource      String? @map("UTM_SOURCE") @db.VarChar(100)
  utmMedium      String? @map("UTM_MEDIUM") @db.VarChar(100)
  utmCampaign    String? @map("UTM_CAMPAIGN") @db.VarChar(100)
  referrerUrl    String? @map("REFERRER_URL") @db.Text
  landingPageUrl String? @map("LANDING_PAGE_URL") @db.Text

  leadSourceId Int? @map("LEAD_SOURCE_ID")
  leadSource   LeadSource? @relation(fields: [leadSourceId], references: [id])

  requestStatusId Int     @map("REQUEST_STATUS_ID")
  marketingConsent       Boolean @default(false) @map("MARKETING_CONSENT")
  ipAddress        String?       @map("IP_ADDRESS") @db.VarChar(45)

  requestType     RequestType  @relation(fields: [requestTypeId], references: [id])
  requestStatus   RequestStatus @relation(fields: [requestStatusId], references: [id])

  // Relations (Internal Team Assignment)
  assignedAssociateId Int?       @map("ASSIGNED_ASSOCIATE_ID")
  assignedTo          Associate? @relation("AssignedAssociate", fields: [assignedAssociateId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt         DateTime  @default(now()) @map("CREATED_AT")
  updatedAt         DateTime  @updatedAt @map("UPDATED_AT")
  resolvedAt        DateTime? @map("RESOLVED_AT")
  
  createdByPersonId Int?      @map("CREATED_BY_PERSON_ID") 
  updatedByPersonId Int?      @map("UPDATED_BY_PERSON_ID")
  
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  createdPerson Person? @relation("ContactRequestCreatedByRelation", fields: [createdByPersonId], references: [id])

  updatedPerson Person? @relation("ContactRequestUpdatedByRelation", fields: [updatedByPersonId], references: [id])
  
  // Indexes for faster lookups in the CRM dashboard

  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([email])
  @@index([requestStatusId])
  @@index([assignedAssociateId])
  @@index([tenantId], name: "idx_cr_tenant")
  @@map("CONTACT_REQUESTS")
}

