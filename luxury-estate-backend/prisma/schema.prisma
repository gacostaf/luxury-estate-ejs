  updatedAt     DateTime  @updatedAt @map("UPDATED_AT")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  coverImage    Image?    @relation("NewsletterIssueCoverImage", fields: [coverImageId], references: [id])
  createdBy     Person?   @relation("NewsletterIssueCreatedBy", fields: [createdById], references: [id])

  sections      NewsletterSection[]
  contents      NewsletterContent[]
  campaigns     NewsletterCampaign[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, slug])
  @@index([publishedAt], name: "idx_newsletter_published")
  @@index([isPublished], name: "idx_newsletter_status")
  @@index([tenantId], name: "idx_ni_tenant")
  @@map("NEWSLETTER_ISSUES")
}

model NewsletterSection {
  id                 Int              @id @default(autoincrement()) @map("ID")
  tenantId           Int              @map("TENANT_ID")
  newsletterIssueId  Int              @map("NEWSLETTER_ISSUE_ID")

  title              String           @map("TITLE") @db.VarChar(255)
  sortOrder          Int              @default(0) @map("SORT_ORDER")

  content            String?          @map("CONTENT") @db.Text

  tenant             Tenant           @relation(fields: [tenantId], references: [id])
  newsletterIssue    NewsletterIssue  @relation(fields: [newsletterIssueId], references: [id], onDelete: Cascade)


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([newsletterIssueId], name: "idx_newsletter_section_issue")
  @@index([tenantId], name: "idx_ns_tenant")

  @@map("NEWSLETTER_SECTIONS")
}

model NewsletterContent {
  id                      Int                       @id @default(autoincrement()) @map("ID")
  tenantId                Int                       @map("TENANT_ID")

  newsletterIssueId       Int                       @map("NEWSLETTER_ISSUE_ID")

  newsletterContentTypeId Int                       @map("NEWSLETTER_CONTENT_TYPE_ID")

  referenceId             Int                       @map("REFERENCE_ID")

  sortOrder               Int                       @default(0) @map("SORT_ORDER")

  tenant                  Tenant                    @relation(fields: [tenantId], references: [id])
  newsletterIssue         NewsletterIssue            @relation(fields: [newsletterIssueId], references: [id], onDelete: Cascade)

  newsletterContentType   NewsletterContentType      @relation(fields: [newsletterContentTypeId], references: [id])


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([newsletterIssueId], name: "idx_newsletter_content_issue")
  @@index([newsletterContentTypeId], name: "idx_newsletter_content_type")
  @@index([tenantId], name: "idx_nc_tenant")

  @@map("NEWSLETTER_CONTENT")
}

model NewsletterContentType {
  id                  Int                  @id @default(autoincrement()) @map("ID")
  tenantId            Int                  @map("TENANT_ID")
  code                String               @map("CODE")
  name                String               @map("NAME") @db.VarChar(100)
  description         String?              @map("DESCRIPTION") @db.Text
  isActive            Boolean              @default(true) @map("IS_ACTIVE")
  sortOrder           Int                  @default(0) @map("SORT_ORDER")
  createdAt           DateTime             @default(now()) @map("CREATED_AT")
  updatedAt           DateTime             @updatedAt @map("UPDATED_AT")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  newsletterContents  NewsletterContent[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("NEWSLETTER_CONTENT_TYPES")
}

model NewsletterCampaign {
  id                 Int               @id @default(autoincrement()) @map("ID")
  tenantId           Int               @map("TENANT_ID")
  newsletterIssueId  Int               @map("NEWSLETTER_ISSUE_ID")

  sentAt             DateTime?         @map("SENT_AT")

  recipientsCount    Int               @default(0) @map("RECIPIENTS_COUNT")
  openCount          Int               @default(0) @map("OPEN_COUNT")
  clickCount         Int               @default(0) @map("CLICK_COUNT")

  createdAt          DateTime          @default(now()) @map("CREATED_AT")

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  newsletterIssue    NewsletterIssue   @relation(fields: [newsletterIssueId], references: [id], onDelete: Cascade)


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([newsletterIssueId], name: "idx_newsletter_campaign_issue")
  @@index([tenantId], name: "idx_campaign_tenant")

  @@map("NEWSLETTER_CAMPAIGNS")
}

// =====================================================
// NEWSLETTER SUBSCRIPTIONS
// =====================================================

model NewsletterSubscription {
  id               Int       @id @default(autoincrement()) @map("ID")
  tenantId         Int       @map("TENANT_ID")

  personId         Int       @unique @map("PERSON_ID")

  isSubscribed     Boolean   @default(true) @map("IS_SUBSCRIBED")

  subscribedAt     DateTime  @default(now()) @map("SUBSCRIBED_AT")
  unsubscribedAt   DateTime? @map("UNSUBSCRIBED_AT")

  source           String?   @map("SOURCE") @db.VarChar(100)
  leadSourceId Int? @map("LEAD_SOURCE_ID")
  leadSource   LeadSource? @relation(fields: [leadSourceId], references: [id])

  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  person           Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  categories       NewsletterSubscriptionCategory[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([isSubscribed], name: "idx_newsletter_subscribed")
  @@index([tenantId], name: "idx_sub_tenant")

  @@map("NEWSLETTER_SUBSCRIPTIONS")
}

model NewsletterCategory {
  id              Int                                @id @default(autoincrement()) @map("ID")
  tenantId        Int                                @map("TENANT_ID")
  code            String                             @map("CODE")
  name            String                             @map("NAME") @db.VarChar(100)
  isActive        Boolean                            @default(true) @map("IS_ACTIVE")
  sortOrder       Int                                @default(0) @map("SORT_ORDER")
  createdAt       DateTime                           @default(now()) @map("CREATED_AT")
  updatedAt       DateTime                           @updatedAt @map("UPDATED_AT")

  tenant          Tenant                             @relation(fields: [tenantId], references: [id])
  subscriptions   NewsletterSubscriptionCategory[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("NEWSLETTER_CATEGORIES")
}

model NewsletterSubscriptionCategory {
  id                         Int                       @id @default(autoincrement()) @map("ID")
  tenantId                   Int                       @map("TENANT_ID")

  newsletterSubscriptionId   Int                       @map("NEWSLETTER_SUBSCRIPTION_ID")
  newsletterCategoryId       Int                       @map("NEWSLETTER_CATEGORY_ID")

  tenant                     Tenant                    @relation(fields: [tenantId], references: [id])
  newsletterSubscription     NewsletterSubscription    @relation(fields: [newsletterSubscriptionId], references: [id], onDelete: Cascade)

  newsletterCategory         NewsletterCategory        @relation(fields: [newsletterCategoryId], references: [id], onDelete: Cascade)


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([newsletterSubscriptionId, newsletterCategoryId], name: "uq_newsletter_subscription_category")

  @@index([newsletterSubscriptionId], name: "idx_newsletter_sub")
  @@index([newsletterCategoryId], name: "idx_newsletter_category")
  @@index([tenantId], name: "idx_nsc_tenant")

  @@map("NEWSLETTER_SUBSCRIPTION_CATEGORIES")
}

model RequestType {
  id              Int              @id @default(autoincrement()) @map("ID")
  tenantId        Int              @map("TENANT_ID")
  code            String           @map("CODE")
  name            String           @map("NAME")
