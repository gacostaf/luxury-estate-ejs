  builtYear         Int?      @map("BUILT_YEAR")
  propertyTypeId    Int       @map("PROPERTY_TYPE_ID")
  propertyStatusId  Int       @map("PROPERTY_STATUS_ID")
  lotSize           Decimal?  @map("LOT_SIZE") @db.Decimal(10, 2)
  hoaFees           Decimal?  @map("HOA_FEES") @db.Decimal(8, 2)
  mlsId             String?   @map("MLS_ID")
  latitude          Decimal?  @map("LATITUDE") @db.Decimal(9, 6)
  longitude         Decimal?  @map("LONGITUDE") @db.Decimal(9, 6)
  isFeatured        Boolean   @default(false) @map("IS_FEATURED")
  isPublished       Boolean   @default(false) @map("IS_PUBLISHED")
  virtualTourUrl    String?   @map("VIRTUAL_TOUR_URL") @db.VarChar(2048)
  videoTourUrl      String?   @map("VIDEO_TOUR_URL") @db.VarChar(2048)
  metaTitle         String?   @map("META_TITLE") @db.VarChar(255)
  metaDescription   String?   @map("META_DESCRIPTION") @db.Text
  agencyId          Int?      @map("AGENCY_ID")
  addressId         Int?      @map("ADDRESS_ID")
  
  agentId           Int?      @map("AGENT_ID")
  createdByPersonId Int?      @map("CREATED_BY_PERSON_ID") 
  updatedByPersonId Int?      @map("UPDATED_BY_PERSON_ID")

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  agent Person? @relation("PropertyAgentRelation", fields: [agentId], references: [id])

  createdPerson Person? @relation("PropertyCreatedByRelation", fields: [createdByPersonId], references: [id])

  updatedPerson Person? @relation("PropertyUpdatedByRelation", fields: [updatedByPersonId], references: [id])

  createdAt DateTime @default(now()) @map("CREATED_AT")
  updatedAt DateTime @default(now()) @map("UPDATED_AT")

  propertyType   PropertyType    @relation(fields: [propertyTypeId], references: [id])
  propertyStatus PropertyStatus  @relation(fields: [propertyStatusId], references: [id])

  agency         Agency?         @relation("AgencyProperties", fields: [agencyId], references: [id])

  bannerImage    Image?          @relation("BannerImage", fields: [bannerImageId], references: [id], onDelete: Restrict)
  address        Address?        @relation("PropertyAddress", fields: [addressId], references: [id], onDelete: SetNull)

  propertyImages PropertyImage[]
  propertyVideos PropertyVideo[]
  reviews        PropertyReview[]
  tourRequests   TourRequest[]
  inquiries      PropertyInquiry[] @relation("PropertyInquiries")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([price], name: "idx_price")
  @@index([bedrooms, bathrooms], name: "idx_room_counts")
  @@index([mlsId], name: "idx_mls_id")
  @@index([publishDate], name: "idx_publish_date")
  @@index([latitude, longitude], name: "idx_coordinates")
  @@index([propertyStatusId, price, publishDate], name: "idx_active_listings")
  @@index([addressLocality, addressRegion, addressCountry], name: "idx_location_schema_org")
  @@index([postalCode], name: "idx_postal_code")
  @@unique([tenantId, slug])
  @@index([tenantId], name: "idx_property_tenant")
  @@map("PROPERTIES")
}

