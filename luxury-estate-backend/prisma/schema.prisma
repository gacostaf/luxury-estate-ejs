  streetAddress     String?   @map("STREET_ADDRESS") @db.VarChar(500)
  addressLocality   String?   @map("ADDRESS_LOCALITY") @db.VarChar(200)
  addressRegion     String?   @map("ADDRESS_REGION") @db.VarChar(100)
  postalCode        String?   @map("POSTAL_CODE") @db.VarChar(20)
  addressCountry    String?   @map("ADDRESS_COUNTRY") @db.Char(2)
