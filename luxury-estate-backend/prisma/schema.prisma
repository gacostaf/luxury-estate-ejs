datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ================= MULTI-TENANCY =================

model Tenant {
  id              Int      @id @default(autoincrement()) @map("ID")
  name            String   @unique @map("NAME") @db.VarChar(100)
  slug            String   @unique @map("SLUG") @db.VarChar(100)
  domain          String?  @unique @map("DOMAIN") @db.VarChar(255)
  logoUrl         String?  @map("LOGO_URL") @db.VarChar(2048)
  faviconUrl      String?  @map("FAVICON_URL") @db.VarChar(2048)
  primaryColor    String?  @default("#1a365d") @map("PRIMARY_COLOR") @db.VarChar(7)
  isActive        Boolean  @default(true) @map("IS_ACTIVE")
  createdAt       DateTime @default(now()) @map("CREATED_AT")
  updatedAt       DateTime @updatedAt @map("UPDATED_AT")

  settings TenantSettings?

  personTypes             PersonType[]
  propertyTypes           PropertyType[]
  propertyStatuses        PropertyStatus[]
  disqualificationStatuses DisqualificationStatus[]
  disqualificationReasons DisqualificationReason[]
  associateTypes          AssociateType[]
  contactMethods          ContactMethod[]
  leadSources             LeadSource[]
  requestTypes            RequestType[]
  requestStatuses         RequestStatus[]
  tourTypes               TourType[]
  tourStatuses            TourStatus[]
  reviewModerationStatuses ReviewModerationStatus[]
  newsletterCategories    NewsletterCategory[]
  newsletterContentTypes  NewsletterContentType[]
  roles                   Role[]
  rolePermissions         RolePermission[]
  personRoles             PersonRole[]
  persons                 Person[]
  authAccounts            AuthAccount[]
  agencies                Agency[]
  associates              Associate[]
  offices                 Office[]
  properties              Property[]
  propertyImages          PropertyImage[]
  propertyReviews         PropertyReview[]
  propertyInquiries       PropertyInquiry[]
  contactRequests         ContactRequest[]
  tourRequests            TourRequest[]
  blogPosts               BlogPost[]
  newsletterIssues        NewsletterIssue[]
  newsletterCampaigns     NewsletterCampaign[]
  newsletterSubscriptions NewsletterSubscription[]
  addresses               Address[]
  images                  Image[]
  videos                  Video[]
  propertyVideos          PropertyVideo[]
  personPermissions       PersonPermission[]
  newsletterContents      NewsletterContent[]
  newsletterSections      NewsletterSection[]
  newsletterSubscriptionCategories NewsletterSubscriptionCategory[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@map("TENANTS")
}

model TenantSettings {
  id                   Int     @id @default(autoincrement()) @map("ID")
  tenantId             Int     @unique @map("TENANT_ID")
  companyName          String? @map("COMPANY_NAME") @db.VarChar(200)
  tagline              String? @map("TAGLINE") @db.VarChar(500)
  contactEmail         String? @map("CONTACT_EMAIL") @db.VarChar(254)
  contactPhone         String? @map("CONTACT_PHONE") @db.VarChar(50)
  address              String? @map("ADDRESS") @db.VarChar(500)
  socialFacebook       String? @map("SOCIAL_FACEBOOK") @db.VarChar(2048)
  socialInstagram      String? @map("SOCIAL_INSTAGRAM") @db.VarChar(2048)
  socialLinkedin       String? @map("SOCIAL_LINKEDIN") @db.VarChar(2048)
  socialTwitter        String? @map("SOCIAL_TWITTER") @db.VarChar(2048)
  googleAnalyticsId    String? @map("GOOGLE_ANALYTICS_ID") @db.VarChar(50)
  metaTitle            String? @map("META_TITLE") @db.VarChar(255)
  metaDescription      String? @map("META_DESCRIPTION") @db.Text
  customCss            String? @map("CUSTOM_CSS") @db.Text
  customJs             String? @map("CUSTOM_JS") @db.Text
  createdAt            DateTime @default(now()) @map("CREATED_AT")
  updatedAt            DateTime @updatedAt @map("UPDATED_AT")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@map("TENANT_SETTINGS")
}

// ================= LOOKUP TABLES =================

model PersonType {
  id          Int      @id @default(autoincrement()) @map("ID")
  tenantId    Int      @map("TENANT_ID")
  code        String   @map("CODE")
  name        String   @map("NAME")
  description String?  @map("DESCRIPTION") @db.Text
  isActive    Boolean  @default(true) @map("IS_ACTIVE")
  sortOrder   Int      @default(0) @map("SORT_ORDER")
  createdAt   DateTime @default(now()) @map("CREATED_AT")
  updatedAt   DateTime @updatedAt @map("UPDATED_AT")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  persons Person[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("PERSON_TYPES")
}

model PropertyType {
  id          Int        @id @default(autoincrement()) @map("ID")
  tenantId    Int        @map("TENANT_ID")
  code        String     @map("CODE")
  name        String     @map("NAME")
  description String?    @map("DESCRIPTION") @db.Text
  isActive    Boolean    @default(true) @map("IS_ACTIVE")
  sortOrder   Int        @default(0) @map("SORT_ORDER")
  createdAt   DateTime   @default(now()) @map("CREATED_AT")
  updatedAt   DateTime   @updatedAt @map("UPDATED_AT")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  properties Property[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("PROPERTY_TYPES")
}

model PropertyStatus {
  id          Int        @id @default(autoincrement()) @map("ID")
  tenantId    Int        @map("TENANT_ID")
  code        String     @map("CODE")
  name        String     @map("NAME")
  description String?    @map("DESCRIPTION") @db.Text
  isActive    Boolean    @default(true) @map("IS_ACTIVE")
  sortOrder   Int        @default(0) @map("SORT_ORDER")
  createdAt   DateTime   @default(now()) @map("CREATED_AT")
  updatedAt   DateTime   @updatedAt @map("UPDATED_AT")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  properties Property[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("PROPERTY_STATUSES")
}

model DisqualificationStatus {
  id        Int                      @id @default(autoincrement()) @map("ID")
  tenantId  Int                      @map("TENANT_ID")
  code      String                   @map("CODE")
  name      String                   @map("NAME") @db.VarChar(50)
  isActive  Boolean                  @default(true) @map("IS_ACTIVE")
  sortOrder Int                      @default(0) @map("SORT_ORDER")
  createdAt DateTime                 @default(now()) @map("CREATED_AT")
  updatedAt DateTime                 @updatedAt @map("UPDATED_AT")

  tenant  Tenant                    @relation(fields: [tenantId], references: [id])
  reasons DisqualificationReason[]
  persons Person[]                  @relation("PersonDQStatus")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@map("DISQUALIFICATION_STATUSES")
}

model DisqualificationReason {
  id          Int                    @id @default(autoincrement()) @map("ID")
  tenantId    Int                    @map("TENANT_ID")
  statusId    Int                    @map("ID_DISQUALIFYING_STATUS")
  reason      String                 @map("REASON") @db.VarChar(100)
  description String?                @map("DESCRIPTION") @db.Text

  tenant Tenant                    @relation(fields: [tenantId], references: [id])
  status DisqualificationStatus @relation(fields: [statusId], references: [id])
  persons Person[]               @relation("PersonDQReason")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, reason])
  @@index([statusId, reason], name: "idx_dq_status_reason")
  @@map("DISQUALIFICATION_REASONS")
}

model Country {
  id        Int       @id @default(autoincrement()) @map("ID")
  name      String    @unique @map("NAME")
  code002   String    @unique @map("CODE002") @db.Char(2)
  code003   String    @unique @map("CODE003") @db.Char(3)
  codenum   String    @unique @map("CODENUM") @db.Char(3)
  tld       String    @unique @map("TLD")
  states    State[]
  cities    City[]
  addresses Address[]

  @@map("COUNTRIES")
}

model State {
  id        Int       @id @default(autoincrement()) @map("ID")
  countryId Int       @map("COUNTRY_ID")
  stateCode String    @map("STATE_CODE") @db.VarChar(10)
  territory String    @map("TERRITORY") @db.VarChar(30)
  country   Country   @relation(fields: [countryId], references: [id])
  cities    City[]
  addresses Address[]

  @@unique([countryId, stateCode], name: "uq_country_state")
  @@index([countryId], name: "idx_state_country")
  @@map("STATES")
}

model City {
  id        Int       @id @default(autoincrement()) @map("ID")
  countryId Int       @map("COUNTRY_ID")
  stateId   Int       @map("STATE_ID")
  cityName  String    @map("CITY_NAME") @db.VarChar(200)
  country   Country   @relation(fields: [countryId], references: [id])
  state     State     @relation(fields: [stateId], references: [id])
  addresses Address[]

  @@index([countryId, stateId], name: "idx_city_country_state")
  @@map("CITIES")
}

// ================= ADDRESS TABLE (Schema.org Compatible) =================

model Address {
  id               Int      @unique @id @default(autoincrement()) @map("ID")
  tenantId         Int      @map("TENANT_ID")
  recipient        String?  @map("RECIPIENT") @db.VarChar(255)
  organization     String?  @map("ORGANIZATION") @db.VarChar(255)
  addressStreet    String   @map("ADDRESS_STREET") @db.VarChar(500)
  addressCityId    Int      @map("ADDRESS_CITY_ID")
  addressRegionId  Int      @map("ADDRESS_REGION_ID")
  postalCode       String   @map("POSTAL_CODE") @db.VarChar(20)
  addressCountryId Int      @map("ADDRESS_COUNTRY_ID")
  latitude         Decimal? @map("LATITUDE") @db.Decimal(9, 6)
  longitude        Decimal? @map("LONGITUDE") @db.Decimal(9, 6)
  createdAt        DateTime @default(now()) @map("CREATED_AT")
  updatedAt        DateTime @updatedAt @map("UPDATED_AT")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  city    City    @relation(fields: [addressCityId], references: [id])
  region  State   @relation(fields: [addressRegionId], references: [id])
  country Country @relation(fields: [addressCountryId], references: [id])

  properties Property[] @relation("PropertyAddress")
  offices    Office[]   @relation("OfficeAddress")

  agency Agency? @relation("AgencyAddress")
  agencies Agency[] @relation("AgencyAddresses")  

  persons Person[] @relation("PersonAddress")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([addressCountryId, addressRegionId, addressCityId], name: "idx_address_location")
  @@index([postalCode], name: "idx_address_zip")
  @@index([latitude, longitude], name: "idx_address_coords")
  @@index([recipient, organization], name: "idx_address_entities")
  @@index([tenantId], name: "idx_address_tenant")
  @@map("ADDRESSES")
}

// ================= CORE ENTITIES =================

model Person {
  id                       Int     @id @default(autoincrement()) @map("ID")
  tenantId                 Int     @map("TENANT_ID")
  personTypeId             Int     @map("PERSON_TYPE")
  firstName                String? @map("FIRST_NAME")
  lastName                 String? @map("LAST_NAME")
  phone                    String? @map("PHONE")
  email                    String? @unique @map("EMAIL") @db.VarChar(254)
  slug                     String  @map("SLUG") @db.VarChar(255)
  notes                    String? @map("NOTES") @db.Text
  isLead                   Boolean @default(false) @map("IS_LEAD")
  isClient                 Boolean @default(false) @map("IS_CLIENT")
  isDisqualified           Boolean @default(false) @map("IS_DISQUALIFIED")
  isAssociate              Boolean @default(false) @map("IS_ASSOCIATE")
  disqualificationStatusId Int?    @map("DISQUALIFICATION_STATUS_ID")
  disqualificationReasonId Int?    @map("DISQUALIFICATION_REASON_ID")
  addressId                Int?    @map("ADDRESS_ID")

  tenant                 Tenant                   @relation(fields: [tenantId], references: [id])
  personType             PersonType               @relation(fields: [personTypeId], references: [id])
  disqualificationStatus DisqualificationStatus?  @relation("PersonDQStatus", fields: [disqualificationStatusId], references: [id])
  disqualificationReason DisqualificationReason?  @relation("PersonDQReason", fields: [disqualificationReasonId], references: [id])
  address                Address?                 @relation("PersonAddress", fields: [addressId], references: [id], onDelete: SetNull)
  associate              Associate?
  authAccount            AuthAccount?

  images Image[] @relation("PersonImages")

  personRoles            PersonRole[]
  personPermissions      PersonPermission[]

  managedAgencyEntities  Agency[] @relation("AgencyManagerRelation")
  createdAgencyEntities  Agency[] @relation("AgencyCreatedByRelation")
  updatedAgencyEntities  Agency[] @relation("AgencyUpdatedByRelation")

  managedOfficeEntities  Office[] @relation("OfficeManagerRelation")
  createdOfficeEntities  Office[] @relation("OfficeCreatedByRelation")
  updatedOfficeEntities  Office[] @relation("OfficeUpdatedByRelation")

  createdImageEntities  Image[] @relation("ImageCreatedByRelation")
  updatedImageEntities  Image[] @relation("ImageUpdatedByRelation")

  createdVideoEntities  Video[] @relation("VideoCreatedByRelation")
  updatedVideoEntities  Video[] @relation("VideoUpdatedByRelation")

  agentPropertyEntities    Property[] @relation("PropertyAgentRelation")
  createdPropertyEntities  Property[] @relation("PropertyCreatedByRelation")
  updatedPropertyEntities  Property[] @relation("PropertyUpdatedByRelation")

  authorBlogPostEntities   BlogPost[] @relation("BlogPostAuthorRelation")
  createdBlogPostEntities  BlogPost[] @relation("BlogPostCreatedByRelation")
  updatedBlogPostEntities  BlogPost[] @relation("BlogPostUpdatedByRelation")

  propertyReviews    PropertyReview[] @relation("PropertyReviewPersonRelation")
  moderatedReviews   PropertyReview[] @relation("ReviewModeratorRelation")

  createdContactRequestEntities  ContactRequest[] @relation("ContactRequestCreatedByRelation")
  updatedContactRequestEntities  ContactRequest[] @relation("ContactRequestUpdatedByRelation")

  clientTours  TourRequest[] @relation("ClientTourRelation")

  createdNewsletterIssues NewsletterIssue[] @relation("NewsletterIssueCreatedBy")
  newsletterSubscription  NewsletterSubscription?
  propertyInquiries  PropertyInquiry[] @relation("PropertyInquiryPersonRelation")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, slug])
  @@index([personTypeId, isLead], name: "idx_person_type_lead")
  @@index([tenantId], name: "idx_person_tenant")
  @@map("PERSONS")
}

model AuthAccount {
  id                  Int       @id @default(autoincrement()) @map("ID")
  tenantId            Int       @map("TENANT_ID")
  personId            Int       @unique @map("PERSON_ID")
  email               String    @unique @map("EMAIL") @db.VarChar(254)
  passwordHash        String?   @map("PASSWORD_HASH") @db.VarChar(255)
  emailVerified       Boolean   @default(false) @map("EMAIL_VERIFIED")
  failedLoginAttempts Int       @default(0) @map("FAILED_LOGIN_ATTEMPTS")
  lockedUntil         DateTime? @map("LOCKED_UNTIL")
  lastLoginAt         DateTime? @map("LAST_LOGIN_AT")
  passwordChangedAt   DateTime? @map("PASSWORD_CHANGED_AT")
  isActive            Boolean   @default(true) @map("IS_ACTIVE")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now()) @map("CREATED_AT")
  updatedAt           DateTime  @updatedAt @map("UPDATED_AT")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@index([email], name: "idx_auth_email")
  @@index([tenantId], name: "idx_auth_tenant")
  @@map("AUTH_ACCOUNTS")
}

model Agency {
  id            Int     @id @default(autoincrement()) @map("ID")
  tenantId      Int     @map("TENANT_ID")
  name          String  @map("NAME")
  slug          String  @map("SLUG")
  description   String? @map("DESCRIPTION") @db.Text
  logoImageId   Int?    @map("LOGO_IMAGE_ID")
  bannerImageId Int?    @map("BANNER_IMAGE_ID")
  phone         String? @map("PHONE")
  email         String? @map("EMAIL") @db.VarChar(254)
  websiteUrl    String? @map("WEBSITE_URL") @db.VarChar(2048)
  facebookUrl   String? @map("FACEBOOK_URL") @db.VarChar(2048)
  instagramUrl  String? @map("INSTAGRAM_URL") @db.VarChar(2048)
  linkedinUrl   String? @map("LINKEDIN_URL") @db.VarChar(2048)

  addressId Int?   @unique @map("ADDRESS_ID")
  address Address? @relation("AgencyAddress", fields: [addressId], references: [id])
  
  isFeatured Boolean  @default(false) @map("IS_FEATURED")
  isVerified Boolean  @default(false) @map("IS_VERIFIED")
  createdAt  DateTime @default(now()) @map("CREATED_AT")
  updatedAt  DateTime @updatedAt @map("UPDATED_AT")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  logoImage   Image?   @relation("AgencyLogo", fields: [logoImageId], references: [id])
  bannerImage Image?   @relation("AgencyBanner", fields: [bannerImageId], references: [id])

  managerAssociateId Int?   @map("MANAGER_ASSOCIATE_ID")
  createdByPersonId  Int?   @map("CREATED_BY_PERSON_ID")
  updatedByPersonId  Int?   @map("UPDATED_BY_PERSON_ID")
  
  managerPerson Person? @relation("AgencyManagerRelation", fields: [managerAssociateId], references: [id])

  createdPerson Person? @relation("AgencyCreatedByRelation", fields: [createdByPersonId], references: [id])

  updatedPerson Person? @relation("AgencyUpdatedByRelation", fields: [updatedByPersonId], references: [id])

  associates Associate[]
  addresses Address[] @relation("AgencyAddresses")

  properties Property[] @relation("AgencyProperties")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([isFeatured], name: "idx_agency_featured")
  @@index([isVerified], name: "idx_agency_verified")
  @@index([name], name: "idx_agency_name")
  @@index([slug], name: "idx_agency_slug")
  @@index([tenantId], name: "idx_agency_tenant")
  @@map("AGENCIES")
}

model Associate {
  id               Int            @id @default(autoincrement()) @map("ID")
  tenantId         Int            @map("TENANT_ID")
  associateTypeId  Int            @map("ASSOCIATE_TYPE_ID")
  associateType    AssociateType  @relation(fields: [associateTypeId], references: [id])
  personId         Int            @unique @map("PERSON_ID")
  person           Person         @relation(fields: [personId], references: [id])
  slug             String         @map("SLUG") @db.VarChar(255)
  personRoleId     Int?           @map("PERSON_ROLE_ID")
  personRole       PersonRole?    @relation(fields: [personRoleId], references: [id])
  agencyId         Int?           @map("AGENCY_ID")
  agency           Agency?        @relation(fields: [agencyId], references: [id])
  officeId         Int?           @map("OFFICE_ID")
  office           Office?        @relation(fields: [officeId], references: [id])
  department       String?        @map("DEPARTMENT")
  licenseNumber    String?        @map("LICENSE_NUMBER")
  startDate        DateTime?      @map("START_DATE")
  endDate          DateTime?      @map("END_DATE")
  supervisorId     Int?           @map("SUPERVISOR_ID")
  supervisor       Associate?     @relation("AssociateSupervisor", fields: [supervisorId], references: [id])
  subordinates     Associate[]    @relation("AssociateSupervisor")
  commissionPlanId Int?           @map("COMMISION_PLAN_ID")
  bio              String?        @map("BIO") @db.Text
  isPublicProfile  Boolean        @default(true) @map("IS_PUBLIC_PROFILE")
  contactMethodId  Int?           @map("CONTACT_METHOD_ID")
  contactMethod    ContactMethod? @relation(fields: [contactMethodId], references: [id])
  photoId          Int?           @unique @map("PHOTO_ID")
  videoId          Int?           @unique @map("VIDEO_ID")
  fbHandle         String?        @map("FB_HANDLE") @db.VarChar(2048)
  igHandle         String?        @map("IG_HANDLE") @db.VarChar(2048)
  linkedinHandle   String?        @map("LINKEDIN_HANDLE") @db.VarChar(2048)
  photo            Image?         @relation("AssociatePhoto", fields: [photoId], references: [id], onDelete: Restrict)
  video            Video?         @relation("AssociateVideo", fields: [videoId], references: [id], onDelete: Restrict)

  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  assignedRequests ContactRequest[] @relation("AssignedAssociate")
  propertyReviews  PropertyReview[]
  primaryTours     TourRequest[] @relation("PrimaryAssociateTourRelation")
  secondaryTours   TourRequest[] @relation("SecondaryAssociateTourRelation")
  inquiries        PropertyInquiry[] @relation("AssociateInquiries")


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, slug])
  @@index([officeId, department], name: "idx_associate_office_dept")
  @@index([tenantId], name: "idx_associate_tenant")
  @@map("ASSOCIATES")
}

model Role {
  id          Int      @id @default(autoincrement()) @map("ID")
  tenantId    Int      @map("TENANT_ID")
  code        String   @db.VarChar(50) @map("CODE")
  name        String   @db.VarChar(100) @map("NAME")
  description String?  @db.Text @map("DESCRIPTION")
  isActive    Boolean  @default(true) @map("IS_ACTIVE")
  isSystem    Boolean  @default(false) @map("IS_SYSTEM")
  sortOrder   Int      @default(0) @map("SORT_ORDER")
  createdAt   DateTime @default(now()) @map("CREATED_AT")
  updatedAt   DateTime @updatedAt @map("UPDATED_AT")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  personRoles     PersonRole[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, code])
  @@index([tenantId], name: "idx_role_tenant")
  @@map("ROLES")
}

model Permission {
  id                Int                @id @default(autoincrement()) @map("ID")
  code              String             @unique @db.VarChar(100) @map("CODE")
  name              String             @db.VarChar(150) @map("NAME")
  description       String?            @db.Text @map("DESCRIPTION")
  category          String?            @db.VarChar(100) @map("CATEGORY")
  isActive          Boolean            @default(true) @map("IS_ACTIVE")
  isSystem          Boolean            @default(false) @map("IS_SYSTEM")
  sortOrder         Int                @default(0) @map("SORT_ORDER")
  createdAt         DateTime           @default(now()) @map("CREATED_AT")
  updatedAt         DateTime           @updatedAt @map("UPDATED_AT")
  rolePermissions   RolePermission[]
  personPermissions PersonPermission[]

  @@map("PERMISSIONS")
}

model RolePermission {
  roleId       Int @map("ROLE_ID")
  permissionId Int @map("PERMISSION_ID")
  tenantId     Int @map("TENANT_ID")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id])


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@id([roleId, permissionId])
  @@index([tenantId], name: "idx_rp_tenant")
  @@map("ROLE_PERMISSIONS")
}

model PersonRole {
  id       Int @id @default(autoincrement()) @map("ID")
  tenantId Int @map("TENANT_ID")
  personId Int @map("PERSON_ID")
  roleId   Int @map("ROLE_ID")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  associates Associate[]


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([personId, roleId])
  @@index([tenantId], name: "idx_pr_tenant")
  @@map("PERSON_ROLES")
}

model PersonPermission {
  id           Int @id @default(autoincrement()) @map("ID")
  tenantId     Int @map("TENANT_ID")
  personId     Int @map("PERSON_ID")
  permissionId Int @map("PERMISSION_ID")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  person     Person     @relation(fields: [personId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])


  isDeleted          Boolean    @default(false) @map("IS_DELETED")
  @@unique([tenantId, personId, permissionId])
  @@index([tenantId], name: "idx_pp_tenant")
  @@map("PERSON_PERMISSIONS")
}

model AssociateType {
  id          Int         @id @default(autoincrement()) @map("ID")
  tenantId    Int         @map("TENANT_ID")
  code        String      @map("CODE")
  name        String      @map("NAME")
  description String?     @map("DESCRIPTION") @db.Text
  isActive    Boolean     @default(true) @map("IS_ACTIVE")
  sortOrder   Int         @default(0) @map("SORT_ORDER")
