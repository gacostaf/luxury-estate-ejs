datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")  // ✅ This works again in Prisma 6
}

generator client {
  provider = "prisma-client-js"
}

// ================= LOOKUP TABLES =================

model PersonType {
  id      Int      @id @default(autoincrement()) @map("id")
  name    String   @unique @map("name")
  persons Person[]
  @@map("PERSON_TYPES")
}

model PropertyType {
  id         Int        @id @default(autoincrement()) @map("id")
  name       String     @unique @map("name")
  properties Property[]
  @@map("PROPERTY_TYPES")
}

model PropertyStatus {
  id         Int        @id @default(autoincrement()) @map("id")
  name       String     @unique @map("name")
  properties Property[]
  @@map("PROPERTY_STATUS")
}

model DisqualificationStatus {
  id      Int      @id @default(autoincrement()) @map("id")
  name    String   @unique @db.VarChar(50) @map("NAME")
  reasons DisqualificationReason[]
  persons Person[] @relation("PersonDQStatus")
  @@map("DISQUALIFICATION_STATUSES")
}

model DisqualificationReason {
  id          Int                    @id @default(autoincrement()) @map("ID")
  statusId    Int                    @map("ID_DISQUALIFYING_STATUS")
  reason      String                 @unique @db.VarChar(100) @map("REASON")
  description String?                @db.Text @map("DESCRIPTION")
  status      DisqualificationStatus @relation(fields: [statusId], references: [id])
  persons     Person[]               @relation("PersonDQReason")
  @@index([statusId, reason], name: "idx_dq_status_reason")
  @@map("DISQUALIFICATION_REASONS")
}

model Country {
  id        Int       @id @default(autoincrement()) @map("id")
  name      String    @unique @map("Name")
  code002   String    @unique @db.Char(2) @map("CODE002")
  code003   String    @unique @db.Char(3) @map("CODE003")
  codenum   String    @unique @db.Char(3) @map("CODENUM")
  tld       String    @unique @map("TLD")
  states    State[]
  cities    City[]
  @@map("COUNTRIES")
}

model State {
  id           Int        @id @default(autoincrement()) @map("id")
  countryId    Int        @map("country_id")
  stateCode    String     @db.VarChar(10) @map("STATE_CODE")
  territory    String     @db.VarChar(30) @map("TERRITORY")
  country      Country    @relation(fields: [countryId], references: [id])
  cities       City[]
  @@unique([countryId, stateCode], name: "uq_country_state")
  @@index([countryId], name: "idx_state_country")
  @@map("STATES")
}

model City {
  id           Int        @id @default(autoincrement()) @map("id")
  countryId    Int        @map("country_id")
  stateId      Int        @map("state_id")
  cityName     String     @db.VarChar(200) @map("city_name")
  country      Country    @relation(fields: [countryId], references: [id])
  state        State      @relation(fields: [stateId], references: [id])
  @@index([countryId, stateId], name: "idx_city_country_state")
  @@map("CITIES")
}

// ================= ADDRESS TABLE (Schema.org Compatible) =================

model Address {
  id               Int           @id @default(autoincrement()) @map("id")
  recipient        String?       @db.VarChar(255) @map("recipient")
  organization     String?       @db.VarChar(255) @map("organization")
  streetAddress    String        @db.VarChar(500) @map("streetAddress")
  addressLocality  String        @db.VarChar(200) @map("addressLocality")
  addressRegion    String        @db.VarChar(100) @map("addressRegion")
  postalCode       String        @db.VarChar(20) @map("postalCode")
  addressCountry   String        @db.Char(2) @map("addressCountry")
  latitude         Decimal?      @db.Decimal(9,6) @map("latitude")
  longitude        Decimal?      @db.Decimal(9,6) @map("longitude")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  properties       Property[]    @relation("PropertyAddress")
  offices          Office[]      @relation("OfficeAddress")
  persons          Person[]      @relation("PersonAddress")

  @@index([addressCountry, addressRegion, addressLocality], name: "idx_address_location")
  @@index([postalCode], name: "idx_address_zip")
  @@index([latitude, longitude], name: "idx_address_coords")
  @@index([recipient, organization], name: "idx_address_entities")
  @@map("ADDRESSES")
}

// ================= CORE ENTITIES =================

model Person {
  id                       Int                      @id @default(autoincrement()) @map("ID")
  personTypeId             Int                      @map("PERSON_TYPE")
  name                     String                   @map("Name")
  phone                    String?                  @map("Phone")
  email                    String?                  @db.VarChar(254) @unique @map("email")
  description              String?                  @db.Text @map("Description")
  isLead                   Boolean                  @default(false) @map("IS_LEAD")
  isClient                 Boolean                  @default(false) @map("IS_CLIENT")
  isEmployee               Boolean                  @default(false) @map("IS_EMPLOYEE")
  isDisqualified           Boolean                  @default(false) @map("IS_DISQUALIFIED")
  disqualificationStatusId Int?                     @map("DISQUALIFICATION_STATUS_ID")
  disqualificationReasonId Int?                     @map("DISQUALIFICATION_REASON_ID")
  addressId                Int?                     @map("address_id")

  personType               PersonType               @relation(fields: [personTypeId], references: [id])
  disqualificationStatus   DisqualificationStatus?  @relation("PersonDQStatus", fields: [disqualificationStatusId], references: [id])
  disqualificationReason   DisqualificationReason?  @relation("PersonDQReason", fields: [disqualificationReasonId], references: [id])
  address                  Address?                 @relation("PersonAddress", fields: [addressId], references: [id], onDelete: SetNull)
  employee                 Employee?
  agentProperties          Property[]               @relation("AgentProperties")

  @@index([isEmployee, isDisqualified], name: "idx_agent_status")
  @@index([personTypeId, isLead], name: "idx_person_type_lead")
  @@map("PERSON")
}

model Employee {
  id             Int       @id @default(autoincrement()) @map("id")
  personId       Int       @unique @map("PERSON_ID")
  officeId       Int?      @map("OFFICE_ID")
  department     String?   @map("DEPARTMENT")
  photoId        Int?      @unique @map("photo_id")
  videoId        Int?      @unique @map("video_id")
  fbHandle       String?   @db.VarChar(2048) @map("FB_HANDLE")
  igHandle       String?   @db.VarChar(2048) @map("IG_HANDLE")
  linkedinHandle String?   @db.VarChar(2048) @map("LINKEDIN_HANDLE")

  person         Person    @relation(fields: [personId], references: [id])
  office         Office?   @relation(fields: [officeId], references: [id])

  photo          Image?    @relation("EmployeePhoto", fields: [photoId], references: [id], onDelete: Restrict)
  video          Video?    @relation("EmployeeVideo", fields: [videoId], references: [id], onDelete: Restrict)

  @@index([officeId, department], name: "idx_employee_office_dept")
  @@map("EMPLOYEE")
}

model Office {
  id         Int        @id @default(autoincrement()) @map("OFFICE_ID")
  phone      String?    @map("Phone")
  addressId  Int?       @map("address_id")

  address    Address?   @relation("OfficeAddress", fields: [addressId], references: [id], onDelete: SetNull)
  employees  Employee[]

  @@map("OFFICE")
}

// ================= MEDIA TABLES =================

model Image {
  id               Int             @id @default(autoincrement()) @map("ID")
  uri              String          @db.VarChar(2048) @map("URI")
  isPersonal       Boolean         @default(false) @map("IS_PERSONAL")
  propertyImages   PropertyImage[]
  bannerProperties Property[]      @relation("BannerImage")
  employeePhoto    Employee?       @relation("EmployeePhoto")
  @@map("IMAGES")
}

model PropertyImage {
  id         Int      @id @default(autoincrement()) @map("ID")
  propertyId Int      @map("PROPERTY_ID")
  imageId    Int      @map("IMAGE_ID")
  isBanner   Boolean  @default(false) @map("IS_BANNER")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  image      Image    @relation(fields: [imageId], references: [id], onDelete: Restrict)
  @@unique([propertyId, imageId], name: "uq_prop_img")
  @@index([propertyId, isBanner], name: "idx_prop_img_banner")
  @@map("PROPERTY_IMAGES")
}

model Video {
  id               Int             @id @default(autoincrement()) @map("ID")
  uri              String          @db.VarChar(2048) @map("URI")
  isPersonal       Boolean         @default(false) @map("IS_PERSONAL")
  propertyVideos   PropertyVideo[]
  employeeVideo    Employee?       @relation("EmployeeVideo")
  @@map("VIDEOS")
}

model PropertyVideo {
  id         Int      @id @default(autoincrement()) @map("ID")
  propertyId Int      @map("PROPERTY_ID")
  videoId    Int      @map("VIDEO_ID")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Restrict)
  @@unique([propertyId, videoId], name: "uq_prop_vid")
  @@index([propertyId], name: "idx_prop_vid_prop")
  @@map("PROPERTY_VIDEOS")
}

// ================= MAIN TABLE: PROPERTIES =================

model Property {
  id               Int              @id @default(autoincrement()) @map("id")
  name             String           @map("name")
  description      String           @db.Text @map("description")
  summary          String?          @map("summary")
  bannerImageId    Int?             @map("banner_image_id")
  seoUrl           String?          @unique @db.VarChar(255) @map("seo_url")
  publishDate      DateTime?        @map("publish_date")
  price            Decimal?         @db.Decimal(12, 2) @map("price")
  bedrooms         Int?             @map("bedrooms")
  bathrooms        Int?             @map("bathrooms")
  areaSqft         Decimal?         @db.Decimal(8, 2) @map("area_sqft")
  
  // Schema.org compatible denormalized address fields
  streetAddress    String?          @db.VarChar(500) @map("streetAddress")
  addressLocality  String?          @db.VarChar(200) @map("addressLocality")
  addressRegion    String?          @db.VarChar(100) @map("addressRegion")
  postalCode       String?          @db.VarChar(20) @map("postalCode")
  addressCountry   String?          @db.Char(2) @map("addressCountry")
  
  garageSpaces     Int?             @map("garage_spaces")
  builtYear        Int?             @map("built_year")
  propertyTypeId   Int              @map("property_type")
  propertyStatusId Int              @map("property_status")
  lotSize          Decimal?         @db.Decimal(10, 2) @map("lot_size")
  hoaFees          Decimal?         @db.Decimal(8, 2) @map("hoa_fees")
  mlsId            String?          @map("mls_id")
  latitude         Decimal?         @db.Decimal(9, 6) @map("latitude")
  longitude        Decimal?         @db.Decimal(9, 6) @map("longitude")
  energyRating     Int?             @map("energy_rating")
  agentId          Int?             @map("agent_id")
  addressId        Int?             @map("address_id")

  propertyType   PropertyType   @relation(fields: [propertyTypeId], references: [id])
  propertyStatus PropertyStatus @relation(fields: [propertyStatusId], references: [id])
  agent          Person?        @relation("AgentProperties", fields: [agentId], references: [id])
  bannerImage    Image?         @relation("BannerImage", fields: [bannerImageId], references: [id], onDelete: Restrict)
  address        Address?       @relation("PropertyAddress", fields: [addressId], references: [id], onDelete: SetNull)
  propertyImages PropertyImage[]
  propertyVideos PropertyVideo[]

  // Indexes for query performance
  @@index([price], name: "idx_price")
  @@index([bedrooms, bathrooms], name: "idx_room_counts")
  @@index([mlsId], name: "idx_mls_id")
  @@index([publishDate], name: "idx_publish_date")
  @@index([latitude, longitude], name: "idx_coordinates")
  @@index([propertyStatusId, price, publishDate], name: "idx_active_listings")
  @@index([addressLocality, addressRegion, addressCountry], name: "idx_location_schema_org")
  @@index([postalCode], name: "idx_postal_code")

  @@map("Properties")
}